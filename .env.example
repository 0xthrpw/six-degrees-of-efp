# Postgres connection (matches docker-compose.yml — host port 5434 to avoid clashes)
DATABASE_URL=postgresql://sdoe:sdoe@localhost:5434/sdoe

# EFP public API
EFP_API_BASE=https://api.ethfollow.xyz/api/v1

# Crawler bounds (see plan Open Items)
CRAWL_SEED_LIMIT=1000      # leaderboard top-N to seed from
CRAWL_NODE_CAP=50000       # stop expanding once this many nodes are discovered
CRAWL_MAX_DEPTH=3          # BFS depth from seeds
CRAWL_CONCURRENCY=5        # max concurrent EFP requests

# API server
API_PORT=8787
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173
SESSION_SECRET=dev-secret-change-me-32-bytes-min-length
SIWE_DOMAIN=localhost:5173
SIWE_URI=http://localhost:5173

# Web (Vite) - prefixed VITE_ to be exposed to the client
VITE_API_BASE=http://localhost:8787
VITE_WALLETCONNECT_PROJECT_ID=
